# Copy to `.env` at the repo root (gitignored). The server loads this file via
# `--env-file=../../.env` in apps/server dev/start scripts.
#
# Shared data directory — use the same path in every checkout/worktree so sessions,
# settings, and cursor-store survive branch switches. Default without this var is
# `<server cwd>/data` (usually apps/server/data when using `bun run dev`).
NUNCIO_DATA_DIR=$HOME/.nuncio/data

# Optional — comma-separated git repo roots for the project picker
# NUNCIO_PROJECT_ROOTS=$HOME/code,$HOME/Desktop/Oscar

# Optional — Cursor provider (can also be set in Settings UI, encrypted in DB)
# CURSOR_API_KEY=
